{
  "name": "@0xhoneyjar/loa-hounfour",
  "version": "8.6.0",
  "type": "module",
  "description": "Constitutional protocol contracts for an AI agent economy — loa-finn ↔ arrakis integration layer",
  "license": "AGPL-3.0",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/0xHoneyJar/loa-hounfour.git"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./core": {
      "types": "./dist/core/index.d.ts",
      "import": "./dist/core/index.js"
    },
    "./economy": {
      "types": "./dist/economy/index.d.ts",
      "import": "./dist/economy/index.js"
    },
    "./model": {
      "types": "./dist/model/index.d.ts",
      "import": "./dist/model/index.js"
    },
    "./governance": {
      "types": "./dist/governance/index.d.ts",
      "import": "./dist/governance/index.js"
    },
    "./constraints": {
      "types": "./dist/constraints/index.d.ts",
      "import": "./dist/constraints/index.js"
    },
    "./integrity": {
      "types": "./dist/integrity/index.d.ts",
      "import": "./dist/integrity/index.js"
    },
    "./graph": {
      "types": "./dist/graph/index.d.ts",
      "import": "./dist/graph/index.js"
    },
    "./composition": {
      "types": "./dist/composition/index.d.ts",
      "import": "./dist/composition/index.js"
    },
    "./commons": {
      "types": "./dist/commons/index.d.ts",
      "import": "./dist/commons/index.js"
    },
    "./vectors": {
      "types": "./dist/commons/vectors/index.d.ts",
      "import": "./dist/commons/vectors/index.js"
    },
    "./schemas/*": "./schemas/*"
  },
  "files": [
    "dist",
    "schemas",
    "vectors",
    "constraints",
    "RELEASE-INTEGRITY.json"
  ],
  "scripts": {
    "build": "tsc",
    "prepack": "node scripts/prepack-clean.mjs",
    "prepublishOnly": "tsc",
    "schema:generate": "tsx scripts/generate-schemas.ts",
    "schema:check": "tsx scripts/check-schemas.ts",
    "semver:check": "tsx scripts/semver-check.ts",
    "vectors:check": "tsx scripts/check-vectors.ts",
    "vectors:cross-runner": "tsx scripts/cross-runner.ts",
    "vectors:cross-runners": "bash scripts/run-cross-runners.sh",
    "vectors:manifest": "tsx scripts/generate-manifest.ts",
    "vectors:package": "tsx scripts/package-vectors.ts",
    "spec:generate": "tsx scripts/generate-asyncapi.ts",
    "docs:choreography": "tsx scripts/generate-choreography-diagrams.ts",
    "check:migration": "tsx scripts/check-migration.ts",
    "schemas:validate": "tsx scripts/validate-schemas.ts",
    "check:constraints": "tsx scripts/generate-constraints.ts --validate",
    "integrity:generate": "tsx scripts/generate-release-integrity.ts",
    "author:vector": "tsx scripts/author-vectors.ts",
    "check:class-policy-boundary": "tsx scripts/check-class-policy-boundary.ts",
    "check:dist-parity": "tsx scripts/check-dist-parity.ts",
    "check:release-integrity-parity": "tsx scripts/check-release-integrity-parity.ts",
    "check:tarball-budget": "tsx scripts/check-tarball-budget.ts",
    "check:all": "npm run schema:check && npm run vectors:check && npm run check:migration && npm run schemas:validate && npm run check:constraints && npm run check:class-policy-boundary && npm run check:dist-parity && npm run check:release-integrity-parity && npm run check:tarball-budget",
    "test": "vitest run",
    "test:vectors": "vitest run --reporter=verbose tests/vectors/",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@noble/hashes": "^2.0.1",
    "@sinclair/typebox": "^0.34.48",
    "canonicalize": "^2.1.0",
    "jose": "^6.2.2"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "fast-check": "^4.6.0",
    "tsx": "^4.0.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.2"
  },
  "overrides": {
    "rollup": "^4.59.0"
  },
  "engines": {
    "node": ">=22"
  }
}
