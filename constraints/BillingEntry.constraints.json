{
  "$schema": "https://loa-hounfour.dev/schemas/constraint-file.json",
  "schema_id": "BillingEntry",
  "origin": "genesis",
  "contract_version": "5.0.0",
  "expression_version": "1.0",
  "constraints": [
    {
      "id": "billing-valid",
      "expression": "id != null && trace_id != null && tenant_id != null",
      "severity": "error",
      "message": "BillingEntry must have id, trace_id, and tenant_id",
      "fields": [
        "id",
        "trace_id",
        "tenant_id"
      ],
      "type_signature": {
        "id": "string",
        "trace_id": "string",
        "tenant_id": "string"
      }
    },
    {
      "id": "billing-pricing-provenance",
      "expression": "source_completion_id == null || pricing_snapshot != null",
      "severity": "warning",
      "category": "economic",
      "fields": [
        "source_completion_id",
        "pricing_snapshot"
      ],
      "type_signature": {
        "source_completion_id": "string",
        "pricing_snapshot": "object"
      },
      "message": "If billing references a completion, pricing snapshot must be present"
    },
    {
      "id": "billing-reconciliation-delta",
      "expression": "reconciliation_delta_micro == null || reconciliation_mode == 'provider_invoice_authoritative'",
      "severity": "warning",
      "category": "economic",
      "fields": [
        "reconciliation_delta_micro",
        "reconciliation_mode"
      ],
      "type_signature": {
        "reconciliation_delta_micro": "bigint_coercible",
        "reconciliation_mode": "string"
      },
      "message": "Reconciliation delta only valid with provider_invoice_authoritative mode"
    }
  ]
}
