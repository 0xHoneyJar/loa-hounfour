{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.0xhoneyjar.com/loa-hounfour/8.4.0/signer-entry",
  "additionalProperties": false,
  "description": "Cryptographic-material entry inside a Keyring. Binds signer_id + key_ref to a public key, signature kind, scoped trust profile, and lifecycle status.",
  "type": "object",
  "required": [
    "signer_id",
    "key_ref",
    "public_key",
    "signature_type",
    "scoped_trust",
    "signer_status"
  ],
  "properties": {
    "signer_id": {
      "pattern": "^[a-z][a-z0-9_-]{2,63}$",
      "description": "Stable opaque identifier for the signer within its keyring. Lowercase, hyphens / underscores; 3-64 chars.",
      "type": "string"
    },
    "key_ref": {
      "minLength": 1,
      "description": "Consumer-side reference for the underlying secret material (HSM slot, KMS handle, file path, etc.). Hounfour never sees the secret.",
      "type": "string"
    },
    "public_key": {
      "pattern": "^ed25519-pub:[A-Za-z0-9_-]{43,44}$",
      "description": "Ed25519 public key, base64url-encoded, prefixed with \"ed25519-pub:\".",
      "type": "string"
    },
    "signature_type": {
      "$id": "SignatureType",
      "description": "Semantic kind of a signature: what the signer is asserting by signing. Orthogonal to the crypto algorithm.",
      "anyOf": [
        {
          "description": "Signer is asserting a fact they observed or vouch for.",
          "const": "attestation",
          "type": "string"
        },
        {
          "description": "Signer is granting permission for a downstream action.",
          "const": "authorization",
          "type": "string"
        },
        {
          "description": "Signer is binding themselves to a future action or state.",
          "const": "commitment",
          "type": "string"
        },
        {
          "description": "Dev-only marker. NOT a cryptographic guarantee — consumers MUST reject in production.",
          "const": "dev_signature",
          "type": "string"
        }
      ]
    },
    "scoped_trust": {
      "$id": "CapabilityScopedTrust",
      "additionalProperties": false,
      "description": "Per-capability-scope trust levels with default fallback (v6.0.0; v8.5.0 EXTEND adds optional match_strategy + precedence_score per D-007 / OQ-S6).",
      "type": "object",
      "required": [
        "scopes",
        "default_level"
      ],
      "properties": {
        "scopes": {
          "additionalProperties": false,
          "description": "Per-scope trust levels. Missing scopes fall back to default_level.",
          "type": "object",
          "properties": {
            "billing": {
              "$id": "TrustLevel",
              "description": "Trust level assigned to an agent. Forms a total order from untrusted to sovereign.",
              "anyOf": [
                {
                  "const": "untrusted",
                  "type": "string"
                },
                {
                  "const": "basic",
                  "type": "string"
                },
                {
                  "const": "verified",
                  "type": "string"
                },
                {
                  "const": "trusted",
                  "type": "string"
                },
                {
                  "const": "sovereign",
                  "type": "string"
                }
              ]
            },
            "governance": {
              "$id": "TrustLevel",
              "description": "Trust level assigned to an agent. Forms a total order from untrusted to sovereign.",
              "anyOf": [
                {
                  "const": "untrusted",
                  "type": "string"
                },
                {
                  "const": "basic",
                  "type": "string"
                },
                {
                  "const": "verified",
                  "type": "string"
                },
                {
                  "const": "trusted",
                  "type": "string"
                },
                {
                  "const": "sovereign",
                  "type": "string"
                }
              ]
            },
            "inference": {
              "$id": "TrustLevel",
              "description": "Trust level assigned to an agent. Forms a total order from untrusted to sovereign.",
              "anyOf": [
                {
                  "const": "untrusted",
                  "type": "string"
                },
                {
                  "const": "basic",
                  "type": "string"
                },
                {
                  "const": "verified",
                  "type": "string"
                },
                {
                  "const": "trusted",
                  "type": "string"
                },
                {
                  "const": "sovereign",
                  "type": "string"
                }
              ]
            },
            "delegation": {
              "$id": "TrustLevel",
              "description": "Trust level assigned to an agent. Forms a total order from untrusted to sovereign.",
              "anyOf": [
                {
                  "const": "untrusted",
                  "type": "string"
                },
                {
                  "const": "basic",
                  "type": "string"
                },
                {
                  "const": "verified",
                  "type": "string"
                },
                {
                  "const": "trusted",
                  "type": "string"
                },
                {
                  "const": "sovereign",
                  "type": "string"
                }
              ]
            },
            "audit": {
              "$id": "TrustLevel",
              "description": "Trust level assigned to an agent. Forms a total order from untrusted to sovereign.",
              "anyOf": [
                {
                  "const": "untrusted",
                  "type": "string"
                },
                {
                  "const": "basic",
                  "type": "string"
                },
                {
                  "const": "verified",
                  "type": "string"
                },
                {
                  "const": "trusted",
                  "type": "string"
                },
                {
                  "const": "sovereign",
                  "type": "string"
                }
              ]
            },
            "composition": {
              "$id": "TrustLevel",
              "description": "Trust level assigned to an agent. Forms a total order from untrusted to sovereign.",
              "anyOf": [
                {
                  "const": "untrusted",
                  "type": "string"
                },
                {
                  "const": "basic",
                  "type": "string"
                },
                {
                  "const": "verified",
                  "type": "string"
                },
                {
                  "const": "trusted",
                  "type": "string"
                },
                {
                  "const": "sovereign",
                  "type": "string"
                }
              ]
            }
          }
        },
        "default_level": {
          "$id": "TrustLevel",
          "description": "Trust level assigned to an agent. Forms a total order from untrusted to sovereign.",
          "anyOf": [
            {
              "const": "untrusted",
              "type": "string"
            },
            {
              "const": "basic",
              "type": "string"
            },
            {
              "const": "verified",
              "type": "string"
            },
            {
              "const": "trusted",
              "type": "string"
            },
            {
              "const": "sovereign",
              "type": "string"
            }
          ]
        },
        "match_strategy": {
          "description": "How a SignerCompetenceRule.required_capability_scopes set is compared against this profile's scopes. Default behavior on absence is \"subset\" (the trust profile must include every required scope) — preserves v8.4.0 implicit semantics.",
          "anyOf": [
            {
              "const": "exact",
              "type": "string"
            },
            {
              "const": "subset",
              "type": "string"
            },
            {
              "const": "superset",
              "type": "string"
            }
          ]
        },
        "precedence_score": {
          "minimum": 0,
          "maximum": 1000,
          "description": "Tiebreaker when multiple SignerCompetenceRules match the same action. Higher score wins. Absence means \"no preference\" — consumers fall back to rule-list order.",
          "type": "integer"
        }
      }
    },
    "signer_status": {
      "$id": "SignerStatus",
      "description": "Lifecycle state of a SignerEntry within a Keyring. Orthogonal to AgentLifecycleState.",
      "anyOf": [
        {
          "description": "Signer is current and may produce signatures.",
          "const": "active",
          "type": "string"
        },
        {
          "description": "Signer is permanently invalidated (key compromise, intentional rotation, or sanction).",
          "const": "revoked",
          "type": "string"
        },
        {
          "description": "Signer has aged out per the keyring policy. Past signatures remain verifiable; new ones are not accepted.",
          "const": "expired",
          "type": "string"
        }
      ]
    }
  },
  "$comment": "contract_version=8.4.0, min_supported=6.0.0"
}
