  "$id": "https://schemas.0xhoneyjar.com/loa-hounfour/8.5.0/reputation-state",
  "description": "Reputation state-machine state: cold → warming → established → authoritative. Transitions are protocol-fixed.",
  "anyOf": [
    {
      "const": "cold",
      "type": "string"
    },
    {
      "const": "warming",
      "type": "string"
    },
    {
      "const": "established",
      "type": "string"
    },
    {
      "const": "authoritative",
      "type": "string"
    }
  ],
  "$comment": "contract_version=8.5.0, min_supported=6.0.0"
}
