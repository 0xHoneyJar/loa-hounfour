{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "description": "Audit-trail entry recording a single reputation state-machine transition: from-state, to-state, timestamp, and trigger reason.",
  "type": "object",
  "required": [
    "from",
    "to",
    "at",
    "trigger"
  ],
  "properties": {
    "from": {
      "description": "Reputation state-machine state: cold → warming → established → authoritative. Transitions are protocol-fixed.",
      "anyOf": [
        {
          "const": "cold",
          "type": "string"
        },
        {
          "const": "warming",
          "type": "string"
        },
        {
          "const": "established",
          "type": "string"
        },
        {
          "const": "authoritative",
          "type": "string"
        }
      ]
    },
    "to": {
      "description": "Reputation state-machine state: cold → warming → established → authoritative. Transitions are protocol-fixed.",
      "anyOf": [
        {
          "const": "cold",
          "type": "string"
        },
        {
          "const": "warming",
          "type": "string"
        },
        {
          "const": "established",
          "type": "string"
        },
        {
          "const": "authoritative",
          "type": "string"
        }
      ]
    },
    "at": {
      "format": "date-time",
      "type": "string"
    },
    "trigger": {
      "minLength": 1,
      "type": "string"
    }
  },
  "$id": "https://schemas.0xhoneyjar.com/loa-hounfour/8.6.0/reputation-transition",
  "$comment": "contract_version=8.6.0, min_supported=6.0.0"
}
