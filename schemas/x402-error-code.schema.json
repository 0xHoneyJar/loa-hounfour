{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.0xhoneyjar.com/loa-hounfour/8.5.1/x402-error-code",
  "description": "Machine-parseable error code for x402 payment failures (PAYMENT_REQUIRED / NOT_ALLOWLISTED / INFERENCE_FAILED / FEATURE_DISABLED / QUOTE_EXPIRED / INSUFFICIENT_FUNDS).",
  "anyOf": [
    {
      "const": "PAYMENT_REQUIRED",
      "type": "string"
    },
    {
      "const": "NOT_ALLOWLISTED",
      "type": "string"
    },
    {
      "const": "INFERENCE_FAILED",
      "type": "string"
    },
    {
      "const": "FEATURE_DISABLED",
      "type": "string"
    },
    {
      "const": "QUOTE_EXPIRED",
      "type": "string"
    },
    {
      "const": "INSUFFICIENT_FUNDS",
      "type": "string"
    }
  ],
  "$comment": "contract_version=8.5.1, min_supported=6.0.0"
}
