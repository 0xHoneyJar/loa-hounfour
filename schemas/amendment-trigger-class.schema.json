{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.0xhoneyjar.com/loa-hounfour/8.6.0/amendment-trigger-class",
  "description": "Four-member exhaustive enum for what triggered the amendment. Schema enforces enum membership only; severity-correction mapping (e.g. observed_failure → major) is consumer-side.",
  "anyOf": [
    {
      "const": "schema_drift",
      "type": "string"
    },
    {
      "const": "ambiguity",
      "type": "string"
    },
    {
      "const": "out_of_scope_dep",
      "type": "string"
    },
    {
      "const": "observed_failure",
      "type": "string"
    }
  ],
  "$comment": "contract_version=8.6.0, min_supported=6.0.0"
}
