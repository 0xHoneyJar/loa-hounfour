{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.0xhoneyjar.com/loa-hounfour/8.4.0/capability-scoped-trust",
  "additionalProperties": false,
  "description": "Per-capability-scope trust levels with default fallback (v6.0.0; v8.5.0 EXTEND adds optional match_strategy + precedence_score per D-007 / OQ-S6).",
  "type": "object",
  "required": [
    "scopes",
    "default_level"
  ],
  "properties": {
    "scopes": {
      "additionalProperties": false,
      "description": "Per-scope trust levels. Missing scopes fall back to default_level.",
      "type": "object",
      "properties": {
        "billing": {
          "$id": "TrustLevel",
          "description": "Trust level assigned to an agent. Forms a total order from untrusted to sovereign.",
          "anyOf": [
            {
              "const": "untrusted",
              "type": "string"
            },
            {
              "const": "basic",
              "type": "string"
            },
            {
              "const": "verified",
              "type": "string"
            },
            {
              "const": "trusted",
              "type": "string"
            },
            {
              "const": "sovereign",
              "type": "string"
            }
          ]
        },
        "governance": {
          "$id": "TrustLevel",
          "description": "Trust level assigned to an agent. Forms a total order from untrusted to sovereign.",
          "anyOf": [
            {
              "const": "untrusted",
              "type": "string"
            },
            {
              "const": "basic",
              "type": "string"
            },
            {
              "const": "verified",
              "type": "string"
            },
            {
              "const": "trusted",
              "type": "string"
            },
            {
              "const": "sovereign",
              "type": "string"
            }
          ]
        },
        "inference": {
          "$id": "TrustLevel",
          "description": "Trust level assigned to an agent. Forms a total order from untrusted to sovereign.",
          "anyOf": [
            {
              "const": "untrusted",
              "type": "string"
            },
            {
              "const": "basic",
              "type": "string"
            },
            {
              "const": "verified",
              "type": "string"
            },
            {
              "const": "trusted",
              "type": "string"
            },
            {
              "const": "sovereign",
              "type": "string"
            }
          ]
        },
        "delegation": {
          "$id": "TrustLevel",
          "description": "Trust level assigned to an agent. Forms a total order from untrusted to sovereign.",
          "anyOf": [
            {
              "const": "untrusted",
              "type": "string"
            },
            {
              "const": "basic",
              "type": "string"
            },
            {
              "const": "verified",
              "type": "string"
            },
            {
              "const": "trusted",
              "type": "string"
            },
            {
              "const": "sovereign",
              "type": "string"
            }
          ]
        },
        "audit": {
          "$id": "TrustLevel",
          "description": "Trust level assigned to an agent. Forms a total order from untrusted to sovereign.",
          "anyOf": [
            {
              "const": "untrusted",
              "type": "string"
            },
            {
              "const": "basic",
              "type": "string"
            },
            {
              "const": "verified",
              "type": "string"
            },
            {
              "const": "trusted",
              "type": "string"
            },
            {
              "const": "sovereign",
              "type": "string"
            }
          ]
        },
        "composition": {
          "$id": "TrustLevel",
          "description": "Trust level assigned to an agent. Forms a total order from untrusted to sovereign.",
          "anyOf": [
            {
              "const": "untrusted",
              "type": "string"
            },
            {
              "const": "basic",
              "type": "string"
            },
            {
              "const": "verified",
              "type": "string"
            },
            {
              "const": "trusted",
              "type": "string"
            },
            {
              "const": "sovereign",
              "type": "string"
            }
          ]
        }
      }
    },
    "default_level": {
      "$id": "TrustLevel",
      "description": "Trust level assigned to an agent. Forms a total order from untrusted to sovereign.",
      "anyOf": [
        {
          "const": "untrusted",
          "type": "string"
        },
        {
          "const": "basic",
          "type": "string"
        },
        {
          "const": "verified",
          "type": "string"
        },
        {
          "const": "trusted",
          "type": "string"
        },
        {
          "const": "sovereign",
          "type": "string"
        }
      ]
    },
    "match_strategy": {
      "description": "How a SignerCompetenceRule.required_capability_scopes set is compared against this profile's scopes. Default behavior on absence is \"subset\" (the trust profile must include every required scope) — preserves v8.4.0 implicit semantics.",
      "anyOf": [
        {
          "const": "exact",
          "type": "string"
        },
        {
          "const": "subset",
          "type": "string"
        },
        {
          "const": "superset",
          "type": "string"
        }
      ]
    },
    "precedence_score": {
      "minimum": 0,
      "maximum": 1000,
      "description": "Tiebreaker when multiple SignerCompetenceRules match the same action. Higher score wins. Absence means \"no preference\" — consumers fall back to rule-list order.",
      "type": "integer"
    }
  },
  "$comment": "contract_version=8.4.0, min_supported=6.0.0"
}
