{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.0xhoneyjar.com/loa-hounfour/8.7.0/cross-score-report",
  "additionalProperties": false,
  "x-cross-field-validated": true,
  "description": "Signed pairwise cross-scoring attestation. Cross-field rule (no-self-scoring) in constraints/CrossScoreReport.constraints.json.",
  "type": "object",
  "required": [
    "report_id",
    "pairwise_scores",
    "mode",
    "signature",
    "signed_by",
    "signing_key_id",
    "signing_algorithm",
    "signed_at",
    "signing_context",
    "resolved_at"
  ],
  "properties": {
    "report_id": {
      "format": "uuid",
      "description": "UUID v4 identifying this report (also serves as protocol-level nonce).",
      "type": "string"
    },
    "pairwise_scores": {
      "description": "Per-pair score entries; cross-field no-self-scoring rule in constraint file.",
      "type": "array",
      "items": {
        "additionalProperties": false,
        "description": "A single scorer/scored pair with three dimensional scores. Self-scoring rejected by CSR-1.",
        "type": "object",
        "required": [
          "scorer",
          "scored",
          "output_score",
          "reasoning_score",
          "grounding_score"
        ],
        "properties": {
          "scorer": {
            "additionalProperties": false,
            "x-cross-field-validated": true,
            "description": "Canonical agent identity with capability-scoped trust (v6.0.0, BREAKING).",
            "type": "object",
            "required": [
              "agent_id",
              "display_name",
              "agent_type",
              "capabilities",
              "trust_scopes",
              "delegation_authority",
              "max_delegation_depth",
              "governance_weight",
              "contract_version"
            ],
            "properties": {
              "agent_id": {
                "pattern": "^[a-z][a-z0-9_-]{2,63}$",
                "description": "Unique agent identifier (lowercase, 3-64 chars).",
                "type": "string"
              },
              "display_name": {
                "minLength": 1,
                "maxLength": 128,
                "description": "Human-readable agent display name.",
                "type": "string"
              },
              "agent_type": {
                "description": "Classification of agent type in the protocol.",
                "anyOf": [
                  {
                    "const": "model",
                    "type": "string"
                  },
                  {
                    "const": "orchestrator",
                    "type": "string"
                  },
                  {
                    "const": "human",
                    "type": "string"
                  },
                  {
                    "const": "service",
                    "type": "string"
                  },
                  {
                    "const": "composite",
                    "type": "string"
                  }
                ]
              },
              "capabilities": {
                "minItems": 1,
                "description": "Non-empty list of agent capabilities.",
                "type": "array",
                "items": {
                  "minLength": 1,
                  "type": "string"
                }
              },
              "trust_scopes": {
                "additionalProperties": false,
                "description": "Per-capability-scope trust levels with default fallback (v6.0.0; v8.5.0 EXTEND adds optional match_strategy + precedence_score per D-007 / OQ-S6).",
                "type": "object",
                "required": [
                  "scopes",
                  "default_level"
                ],
                "properties": {
                  "scopes": {
                    "additionalProperties": false,
                    "description": "Per-scope trust levels. Missing scopes fall back to default_level.",
                    "type": "object",
                    "properties": {
                      "billing": {
                        "description": "Trust level assigned to an agent. Forms a total order from untrusted to sovereign.",
                        "anyOf": [
                          {
                            "const": "untrusted",
                            "type": "string"
                          },
                          {
                            "const": "basic",
                            "type": "string"
                          },
                          {
                            "const": "verified",
                            "type": "string"
                          },
                          {
                            "const": "trusted",
                            "type": "string"
                          },
                          {
                            "const": "sovereign",
                            "type": "string"
                          }
